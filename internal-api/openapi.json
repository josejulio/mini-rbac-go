{
  "openapi": "3.0.0",
  "info": {
    "title": "Mini RBAC Go - Internal Management API",
    "version": "1.0.0",
    "description": "Internal API for administrative tasks like permission seeding and management",
    "contact": {
      "name": "Mini RBAC Go",
      "url": "https://github.com/redhat/mini-rbac-go"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8085/internal",
      "description": "Local development server"
    }
  ],
  "tags": [
    {
      "name": "Permissions",
      "description": "Permission seeding and management operations"
    }
  ],
  "paths": {
    "/permissions": {
      "get": {
        "tags": ["Permissions"],
        "summary": "List all permissions",
        "description": "Returns a list of all permissions in the system",
        "operationId": "listPermissions",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PermissionListResponse"
                },
                "example": {
                  "permissions": [
                    {
                      "id": 1,
                      "application": "inventory",
                      "resource_type": "hosts",
                      "verb": "read",
                      "v1_string": "inventory:hosts:read",
                      "v2_string": "inventory:hosts:read"
                    }
                  ],
                  "count": 1
                }
              }
            }
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        }
      },
      "post": {
        "tags": ["Permissions"],
        "summary": "Create a permission",
        "description": "Creates a new permission in the system",
        "operationId": "createPermission",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreatePermissionRequest"
              },
              "example": {
                "application": "inventory",
                "resource_type": "hosts",
                "verb": "read"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Permission created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Permission"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "409": {
            "description": "Permission already exists",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        }
      }
    },
    "/permissions/bulk": {
      "post": {
        "tags": ["Permissions"],
        "summary": "Bulk create permissions",
        "description": "Creates multiple permissions at once. Skips duplicates automatically.",
        "operationId": "bulkCreatePermissions",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BulkCreateRequest"
              },
              "example": {
                "permissions": [
                  {
                    "application": "inventory",
                    "resource_type": "hosts",
                    "verb": "read"
                  },
                  {
                    "application": "inventory",
                    "resource_type": "hosts",
                    "verb": "write"
                  },
                  {
                    "application": "inventory",
                    "resource_type": "hosts",
                    "verb": "delete"
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Bulk create completed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BulkCreateResponse"
                },
                "example": {
                  "created": [
                    {
                      "id": 1,
                      "application": "inventory",
                      "resource_type": "hosts",
                      "verb": "read",
                      "v1_string": "inventory:hosts:read",
                      "v2_string": "inventory:hosts:read"
                    }
                  ],
                  "skipped": [
                    "inventory:hosts:write (exists)"
                  ]
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Permission": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Permission ID",
            "example": 1
          },
          "application": {
            "type": "string",
            "description": "Application name",
            "example": "inventory"
          },
          "resource_type": {
            "type": "string",
            "description": "Resource type",
            "example": "hosts"
          },
          "verb": {
            "type": "string",
            "description": "Permission verb/action",
            "example": "read"
          },
          "v1_string": {
            "type": "string",
            "description": "V1 format: app:resource:verb",
            "example": "inventory:hosts:read"
          },
          "v2_string": {
            "type": "string",
            "description": "V2 format: app:resource:verb",
            "example": "inventory:hosts:read"
          }
        }
      },
      "CreatePermissionRequest": {
        "type": "object",
        "required": ["application", "resource_type", "verb"],
        "properties": {
          "application": {
            "type": "string",
            "description": "Application name (no special characters)",
            "example": "inventory"
          },
          "resource_type": {
            "type": "string",
            "description": "Resource type (no special characters)",
            "example": "hosts"
          },
          "verb": {
            "type": "string",
            "description": "Permission verb/action (no special characters)",
            "example": "read"
          }
        }
      },
      "BulkCreateRequest": {
        "type": "object",
        "required": ["permissions"],
        "properties": {
          "permissions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CreatePermissionRequest"
            },
            "description": "Array of permissions to create",
            "minItems": 1
          }
        }
      },
      "BulkCreateResponse": {
        "type": "object",
        "properties": {
          "created": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Permission"
            },
            "description": "Successfully created permissions"
          },
          "skipped": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Skipped permissions (duplicates or errors)",
            "example": ["inventory:hosts:read (exists)", "invalid::verb (invalid)"]
          }
        }
      },
      "PermissionListResponse": {
        "type": "object",
        "properties": {
          "permissions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Permission"
            }
          },
          "count": {
            "type": "integer",
            "description": "Total number of permissions"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "status": {
            "type": "integer",
            "description": "HTTP status code"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request - validation error",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            },
            "example": {
              "error": "application is required",
              "status": 400
            }
          }
        }
      },
      "InternalError": {
        "description": "Internal server error",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            },
            "example": {
              "error": "Failed to create permission",
              "status": 500
            }
          }
        }
      }
    }
  }
}
